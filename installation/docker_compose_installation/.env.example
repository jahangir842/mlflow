# Copy this file to `.env` and change EVERY value below.
#   cp .env.example .env
# `.env` is git-ignored -- never commit real credentials.

# ---- PostgreSQL backend store ----
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=mlflowdb

# ---- MinIO artifact store (S3-compatible) ----
# These double as the S3 access key / secret key for the MLflow server.
MINIO_ROOT_USER=mlflow-minio
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_minio_password
MLFLOW_BUCKET_NAME=mlflow

# ---- MLflow authentication ----
# true  = require a username/password (basic-auth) -- recommended.
# false = open server, anyone who can reach it has full read/write access.
MLFLOW_AUTH_ENABLED=true

# Bootstrap admin (only used on first startup while auth is enabled). After first
# login, manage users via the MLflow auth API and change this password.
MLFLOW_ADMIN_USERNAME=admin
MLFLOW_ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# Stable secret key used by basic-auth for CSRF protection. Generate one with:
#   openssl rand -hex 32
# Keep it constant across restarts (changing it invalidates active sessions).
MLFLOW_FLASK_SERVER_SECRET_KEY=CHANGE_ME_run_openssl_rand_hex_32

# ---- MLflow image ----
# Override if you push the custom image to a registry, e.g.
#   MLFLOW_IMAGE=your-registry/mlflow-with-psycopg2:v3.14.0
MLFLOW_IMAGE=mlflow-with-psycopg2:v3.14.0
