# Copy to secret.yaml, change the values, then `kubectl apply -f secret.yaml`.
# secret.yaml is git-ignored. stringData lets you write plain text; Kubernetes
# stores it base64-encoded. Do NOT commit the real file.
apiVersion: v1
kind: Secret
metadata:
  name: mlflow-secrets
  namespace: mlflow
type: Opaque
stringData:
  POSTGRES_USER: mlflow
  POSTGRES_PASSWORD: CHANGE_ME_strong_db_password
  POSTGRES_DB: mlflowdb
